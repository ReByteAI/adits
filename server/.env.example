# Server (Node/Hono) env template — committed, no real values.
# Copy the keys you need into `server/.env.local` (gitignored) and fill in real values.

# --- Core ---
PORT=4001
DATABASE_URL=
REDIS_URL=

# Which backend to run: 'rebyte' (hosted) or 'local' (self-hosted single-user).
# Keys below marked [rebyte-only] are unused and can stay empty when ADITS_BACKEND=local.
ADITS_BACKEND=

# --- Clerk (auth) [rebyte-only] ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Rebyte Agent Computer API [rebyte-only] ---
REBYTE_API_URL=
REBYTE_CONSOLE_URL=
REBYTE_API_KEY=
REBYTE_WEBHOOK_SECRET=

# Public URL for webhook callbacks from Rebyte
ADITS_PUBLIC_URL=

# --- Misc ---
STATIC_DIR=build

# Local mode only: data dir and file-server port
ADITS_DATA_DIR=
FILE_SERVER_PORT=
