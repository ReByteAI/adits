{
  "name": "adits",
  "version": "0.1.0",
  "description": "Adits — edit your files, effortlessly",
  "license": "SEE LICENSE FILE",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf build",
    "rebuild": "pnpm clean && pnpm build",
    "predev": "pkill -f 'adits/node_modules/.*/vite' 2>/dev/null || true",
    "dev": "vite",
    "predev:server": "pkill -f 'env-file=server/.env.local --import tsx server/index.ts' 2>/dev/null || true",
    "dev:server": "node --env-file=server/.env.local --watch --import tsx server/index.ts",
    "predev:all": "pkill -f 'concurrently -n vite,server' 2>/dev/null || true",
    "dev:all": "concurrently -n vite,server 'pnpm dev' 'pnpm dev:server'",
    "predev:single-user": "pkill -f 'concurrently -n vite,server' 2>/dev/null; pkill -f 'adits-file-server' 2>/dev/null; true",
    "dev:single-user": "concurrently -n vite,server 'VITE_ADITS_BACKEND=local pnpm dev' 'ADITS_BACKEND=local pnpm dev:server'",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/localizations": "^4.5.3",
    "@clerk/themes": "^2.4.57",
    "@floating-ui/react": "^0.27.19",
    "@hono/node-server": "^1.19.14",
    "@lexical/react": "^0.42.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "docx-preview": "^0.3.7",
    "hono": "^4.12.10",
    "html-to-image": "^1.11.13",
    "i18next": "^26.0.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "lexical": "^0.42.0",
    "motion": "^12.23.26",
    "pg": "^8.20.0",
    "playwright": "^1.57.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-pdf": "^10.4.1",
    "rebyte-sandbox": "git+https://github.com/ReByteAI/sandbox-sdk.git#e041be14e9daad23d9a3ac7cff4b3866cd177375",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  }
}
