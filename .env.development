# Frontend (Vite) env template — committed, no real values.
# Copy the keys you need into `.env.local` (gitignored) and fill in real values.
# Only variables prefixed with VITE_ are exposed to client code.

# Clerk publishable key (browser)
VITE_CLERK_PUBLISHABLE_KEY=

# Backend selector: 'rebyte' (hosted) or 'local' (self-hosted single-user)
VITE_ADITS_BACKEND=

# Google Drive Picker (Drive API key + OAuth client ID)
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_CLIENT_ID=
